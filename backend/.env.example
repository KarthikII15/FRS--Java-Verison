PORT=8080
CLIENT_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=FRS
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

KAFKA_ENABLED=false

ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# Auth mode: 'api' or 'keycloak'
AUTH_MODE=api

# Keycloak config (only needed when AUTH_MODE=keycloak)
KEYCLOAK_URL=http://localhost:9090
KEYCLOAK_REALM=attendance

# ── IVIS Cloud External API ────────────────────────────────────────────
# Phase 0: capture the login request from DevTools and fill in below.
IVIS_API_BASE=https://iportal-poc.iviscloud.net/api/client-portal
IVIS_LOGIN_URL=https://iportal-poc.iviscloud.net/api/auth/login
IVIS_SERVICE_USERNAME=your_ivis_username
IVIS_SERVICE_PASSWORD=your_ivis_password

# Static request headers (captured from DevTools)
IVIS_CUSTOMER_ID=445
IVIS_CUSTOMER_NAME=PMSTEST
IVIS_CUSTOMER_CODE=PMSTEST
IVIS_LOGIN_ID=pmstest@gmail.com
IVIS_TENANT_ID=1
IVIS_DEVICE_ID=IVISPMS1001
IVIS_TLS_REJECT_UNAUTHORIZED=false
IVIS_BYPASS_AUTH=false
